{
    "name": "pi-web-access",
    "version": "1.0.0",
    "description": "Web search, URL/content extraction, and web analysis for Pi coding agent — powered by webclaw",
    "type": "module",
    "keywords": [
        "pi-package",
        "pi",
        "pi-coding-agent",
        "extension",
        "web-search",
        "webclaw",
        "fetch",
        "scraping",
        "extraction"
    ],
    "license": "MIT",
    "author": "Nico Bailon",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nicobailon/pi-web-access.git"
    },
    "scripts": {
        "typecheck": "tsc --noEmit",
        "lint": "biome check src/",
        "lint:fix": "biome check --fix --unsafe src/",
        "format": "biome format --write src/",
        "build:curator": "cd curator-ui && npm run build",
        "build": "npm run build:curator",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepublishOnly": "npm run build && npm run typecheck && npm run lint && npm run test",
        "clean": "rm -rf curator-ui/dist"
    },
    "dependencies": {
        "@mozilla/readability": "^0.6.0",
        "linkedom": "^0.18.12",
        "p-limit": "^7.3.0",
        "turndown": "^7.2.4",
        "zod": "^4.3.6"
    },
    "peerDependencies": {
        "@mariozechner/pi-ai": "^0.70.5",
        "@mariozechner/pi-coding-agent": "^0.70.5",
        "@mariozechner/pi-tui": "^0.70.5",
        "@sinclair/typebox": "^0.34.49"
    },
    "devDependencies": {
        "@biomejs/biome": "^1.9.4",
        "typescript": "^5.8.3",
        "vitest": "^3.2.4"
    },
    "pi": {
        "extensions": [
            "./src/index.ts"
        ],
        "skills": [
            "./skills"
        ],
        "video": "https://github.com/nicobailon/pi-web-access/raw/refs/heads/main/pi-web-fetch-demo.mp4"
    }
}
